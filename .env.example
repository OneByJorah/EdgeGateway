# EdgeGateway — Environment Configuration
# Copy this file to .env and fill in your values.
# This is for reference only — the actual config is written to /etc/EdgeGateway/config.env

# ── Network Interfaces ────────────────────────────────────
WAN_IFACE=eth0
AP_IFACE=wlan0

# ── WiFi Access Point ──────────────────────────────────────
AP_SSID=PiGateway
AP_PASS=change_me_wifi_password
AP_CHANNEL=6
AP_COUNTRY=US

# ── AP Network ─────────────────────────────────────────────
AP_IP=192.168.50.1
AP_SUBNET=192.168.50.0/24
AP_DHCP_START=192.168.50.10
AP_DHCP_END=192.168.50.100

# ── Cloudflare WARP ────────────────────────────────────────
WARP_MTU=1280

# ── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=5000

# ── Telegram Bot (optional) ─────────────────────────────────
BOT_TOKEN=
ADMIN_CHAT_ID=
